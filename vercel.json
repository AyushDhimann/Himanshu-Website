{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "nextjs",

  "buildCommand": "npm run build",

  "installCommand": "npm install",

  "regions": ["bom1"],

  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/www",
      "destination": "https://himanshudhiman.website",
      "permanent": true
    }
  ]
}
