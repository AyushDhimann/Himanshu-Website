{
  /**
   * tsconfig.json — TypeScript Configuration
   *
   * This file tells TypeScript (and VS Code) how to understand your code.
   * It also sets up the @/ path alias (like the old jsconfig.json did).
   *
   * TypeScript = JavaScript with TYPES.
   * A "type" tells you what kind of data a variable holds:
   *   string, number, boolean, an array, an object with specific keys, etc.
   *
   * Why bother? TypeScript catches mistakes BEFORE you even run your code.
   * Example: if a function expects a Car object and you pass a number,
   * TypeScript yells at you immediately — not silently in production.
   */
  "compilerOptions": {
    /* -------------------------------------------------------
     * TARGET & LIBRARY
     * target: what JavaScript version to compile down to
     * lib: which browser/environment APIs TypeScript knows about
     * ------------------------------------------------------- */
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    /* -------------------------------------------------------
     * MODULE SETTINGS
     * module: how imports/exports are bundled
     * moduleResolution: "bundler" = let Next.js/Turbopack handle it
     * resolveJsonModule: lets you do `import data from './foo.json'`
     * ------------------------------------------------------- */
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    /* -------------------------------------------------------
     * REACT / JSX
     * "preserve" means Next.js handles the JSX transformation,
     * not the TypeScript compiler. This is correct for Next.js.
     * ------------------------------------------------------- */
    "jsx": "react-jsx",
    /* -------------------------------------------------------
     * STRICT MODE
     * This turns on all of TypeScript's strictest checks.
     * It might feel annoying at first, but it teaches you
     * to write much cleaner, more predictable code.
     * ------------------------------------------------------- */
    "strict": true,
    /* -------------------------------------------------------
     * OTHER USEFUL OPTIONS
     * ------------------------------------------------------- */
    "allowJs": true, /* Allow .js files alongside .ts — good for gradual migration */
    "skipLibCheck": true, /* Don't type-check node_modules (too slow, not your code) */
    "noEmit": true, /* Don't output .js files — Next.js handles that */
    "esModuleInterop": true, /* Makes default imports from CommonJS modules work smoothly */
    "isolatedModules": true, /* Required by Next.js for fast compilation */
    "incremental": true, /* Cache type-checks for faster rebuilds *//* Next.js plugin — adds extra type checking for App Router patterns */
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* -------------------------------------------------------
     * PATH ALIASES
     * @/* → ./*  means @/components/Foo = ./components/Foo
     * This is why we can write:
     *   import Foo from '@/components/Foo'
     * instead of:
     *   import Foo from '../../components/Foo'
     * ------------------------------------------------------- */
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts", /* Auto-generated by Next.js — don't edit */
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
